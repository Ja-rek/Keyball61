#define DEFAULT 0
#define Ja-Rek  1
#define SYM     2
#define MOUSE   3 // Auto-Mouse Layer
#define SCROLL  4 // Motion Scroll Layer
#define SNIPE   5 // Snipe Mode Layer

#include <behaviors/mouse_keys.dtsi>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/mouse.h>

&lt {
    tapping-term-ms = <240>;
    flavor = "balanced";
    quick-tap-ms = <150>;
};

&mt {
    tapping-term-ms = <200>;
    flavor = "tap-preferred";
    quick-tap-ms = <150>;
};

/ {
    keymap {
        compatible = "zmk,keymap";

default_layer {
    label = "QWRT";
    bindings = <
        &kp GRAVE      &kp DOUBLE_QUOTES  &kp APOSTROPHE   &kp EQUAL        &kp EXCLAMATION  &kp PIPE                                       &kp LEFT_BRACKET  &kp LEFT_PARENTHESIS    &kp LEFT_BRACE    &kp QUESTION    &kp AMPERSAND   &kp DOLLAR
        &kp LEFT_WIN   &kp Q              &kp W            &kp E            &kp R            &kp T                                          &kp Y             &kp U                   &kp I             &kp O           &kp P           &kp RIGHT_WIN
        &kp RIGHT_ALT  &kp A              &kp S            &kp D            &kp F            &kp G                                          &kp H             &kp J                   &kp K             &kp L           &kp SEMI        &kp RIGHT_ALT  FT
        &kp LEFT_SHIFT &kp Z              &kp X            &kp C            &kp V            &kp B      &kp SPACE         &kp BACKSPACE     &kp N             &kp M                   &kp COMMA         &kp DOT         &kp FSLH        &kp RIGHT_SHIFT
        &kp LCTRL      &kp C_VOL_DN       &kp C_VOL_UP     &kp CAPS         &lt 5 ESC        &mo 1      &lt 4 TAB         &lt 2 ENTER       &mo 1                                                                       &kp LEFT_ALT    &kp RCTRL      
    >;
};
        number_layer {
            label = "Ja-Rek";
            bindings = <
&trans       &kp F1        &kp F2      &kp F3      &kp F4      &kp F5                          &kp F6                  &kp F7  &kp F8  &kp F9  &kp F10          &kp F11  
&kp AT_SIGN  &kp KP_MINUS  &kp KP_PLUS &kp HASH    &kp PERCENT &kp CARET                       &kp LEFT_BRACKET        &kp N7  &kp N8  &kp N9  &trans           &kp F12
&kp STAR     &kp DEL       &kp LEFT    &kp DOWN    &kp UP      &kp RIGHT                       &kp LEFT_PARENTHESIS    &kp N4  &kp N5  &kp N6  &kp RIGHT_SHIFT  &kp PSCRN
&trans       &trans        &trans      &trans      &trans      &trans  &kp UNDERSCORE  &trans  &kp LEFT_BRACE          &kp N1  &kp N2  &kp N3  &kp N0           &kp RCTRL
&trans       &trans        &trans      &trans      &trans      &trans  &trans          &trans  &trans                                          &trans           &trans
            >;
        };

        symbol_layer {
            label = "SYM";
            bindings = <
&trans  &kp EXCLAMATION  &kp AT_SIGN   &kp HASH      &kp DOLLAR    &kp PERCENT                  &kp CARET       &kp AMPERSAND  &kp ASTERISK      &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &trans
&trans  &trans           &trans        &trans        &trans        &trans                       &trans          &trans         &trans            &trans                &trans                 &trans
&trans  &bt BT_CLR       &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &trans                       &kp MINUS       &kp EQUAL      &kp LEFT_BRACKET  &kp RIGHT_BRACKET     &trans                 &trans
&trans  &trans           &trans        &trans        &trans        &trans       &trans  &trans  &kp UNDERSCORE  &kp PLUS       &trans            &trans                &trans                 &trans
&trans  &trans           &trans        &trans        &trans        &trans       &trans  &trans  &trans                                                                 &trans                 &trans
            >;
        };

        function_layer {
            label = "FUN";
            bindings = <
&trans       &kp F1        &kp F2      &kp F3      &kp F4      &kp F5                          &kp F6                  &kp F7  &kp F8  &kp F9  &kp F10 &kp F11  
&kp AT_SIGN  &kp KP_MINUS  &kp KP_PLUS &kp HASH    &kp PERCENT &kp CARET                       &kp LEFT_BRACKET        &kp N7  &kp N8  &kp N9  &trans  &kp F12
&trans       &kp LEFT      &kp DOWN    &kp UP      &kp RIGHT   &trans                          &kp LEFT_PARENTHESIS    &kp N4  &kp N5  &kp N6  &trans  &kp RIGHT_SHIFT
&trans       &trans        &trans      &trans      &trans      &trans  &kp UNDERSCORE  &trans  &kp LEFT_BRACE          &kp N1  &kp N2  &kp N3  &kp N0  &kp RCTRL
&trans       &trans        &trans      &trans      &trans      &trans  &trans          &trans  &trans                                          &trans  &trans
            >;
        };

        mouse_layer {
            label = "MOUSE";
            bindings = <
&trans  &trans    &trans    &trans  &trans     &trans                  &trans         &trans     &trans  &trans     &trans     &trans
&trans  &trans    &trans    &trans  &trans     &trans                  &trans         &trans     &trans  &trans     &trans     &trans
&trans  &kp LEFT  &kp DOWN  &kp UP  &kp RIGHT  &trans                  &kp PAGE_UP    &mkp LCLK  &trans  &mkp RCLK  &mkp MCLK  &trans
&trans  &trans    &trans    &trans  &trans     &trans  &trans  &trans  &kp PAGE_DOWN  &trans     &trans  &trans     &trans     &trans
&trans  &trans    &trans    &trans  &trans     &trans  &trans  &trans  &mo 3                                        &trans     &trans
            >;
        };

        scroll_layer {
            label = "SCROLL";
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans                  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans                  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans                  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans                          &trans  &trans
            >;
        };

        snipe_layer {
            label = "SNIPE";
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans                  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans                  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans                  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans                          &trans  &trans
            >;
        };
    };
};
